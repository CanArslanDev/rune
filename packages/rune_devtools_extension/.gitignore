# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/ios/Runner/GoogleService-Info.plist
**/android/app/google-service.json
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.vscode/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
# DevTools extension's compiled bundle. Built on demand by
# tool/build_bundle.sh (or any `flutter build web --output=...`
# invocation) before `dart pub publish` or local path-dep testing.
# Not tracked in git: the compiled output is ~30 MB of derived
# artefacts that would bloat history pointlessly.
/extension/devtools/build/
coverage/
pubspec.lock

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter platforms
# Note: /web/ is intentionally NOT ignored here. This package is a
# Flutter DevTools extension; its Flutter-web entry point (index.html,
# flutter_bootstrap, assets) lives under /web/ and ships to consumers
# so DevTools can load the compiled app.
/macos/
/windows/
/linux/

# Android Gradle related
/android/.gradle/
/android/app/.cxx/
/android/local.properties

# iOS CocoaPods related
/ios/Pods/
/ios/.symlinks/
/ios/.flutter-plugins/
/ios/.flutter-plugins-dependencies/
/ios/Podfile.lock

# Project-internal files — kept local, never committed
/docs/
/idea.md
/CLAUDE.md
